# app shortcuts
# Finder
ctrl + shift - f : open ~

# Safari
ctrl + shift - s : osascript -e 'tell application "Safari" to make new document' -e 'tell application "Safari" to activate'

# Kitty
ctrl + shift - t : /Applications/kitty.app/Contents/MacOS/kitty --single-instance --instance-group=kitty -d ~

# Ghostty
# ctrl + shift - t : open -a "Ghostty"

# Nimble Commander
ctrl + shift - n : open -a "Nimble Commander.app"

# Google Chrome
ctrl + shift - c : open -na "Google Chrome" --args --new-window 

# Disable mail shortcut in Safari
cmd - i [
	"safari"       : passthrough
]
cmd + shift - i [
	"safari"       : passthrough
]

# Disable print shortcut in Finder
cmd + shift - p [
	"finder"       : passthrough
]
cmd - p [
	"finder"       : passthrough
]

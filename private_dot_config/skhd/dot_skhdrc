ctrl + shift - 5 : sketchybar --set /space\../ background.drawing=off --set space.5 background.drawing=on; yabai -m window --space 5; yabai -m space --focus 5
ctrl + shift - 6 : sketchybar --set /space\../ background.drawing=off --set space.6 background.drawing=on; yabai -m window --space 6; yabai -m space --focus 6
ctrl + shift - 7 : sketchybar --set /space\../ background.drawing=off --set space.7 background.drawing=on; yabai -m window --space 7; yabai -m space --focus 7

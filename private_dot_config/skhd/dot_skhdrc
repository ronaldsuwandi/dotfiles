cmd + alt - left : yabai -m window --focus west --wrap
cmd + alt - up : yabai -m window --focus north --wrap
cmd + alt - down : yabai -m window --focus south --wrap
cmd + alt - right : yabai -m window --focus east --wrap

# move window
cmd + alt + shift - left : yabai -m window --warp west
cmd + alt + shift - up : yabai -m window --warp north
cmd + alt + shift - down : yabai -m window --warp south
cmd + alt + shift - right : yabai -m window --warp east

# swap window
cmd + ctrl + shift - left : yabai -m window --swap west
cmd + ctrl + shift - up : yabai -m window --swap north
cmd + ctrl + shift - down : yabai -m window --swap south
cmd + ctrl + shift - right : yabai -m window --swap east

cmd + alt + ctrl - left : yabai -m window --resize left:-30:0
cmd + alt + ctrl - right : yabai -m window --resize right:30:0
cmd + alt + ctrl - up : yabai -m window --resize top:0:-30
cmd + alt + ctrl - down : yabai -m window --resize bottom:0:30


cmd + alt - r : yabai -m space --rotate 90
cmd + alt - s : yabai -m window --toggle split
cmd + alt - z : yabai -m window --toggle zoom-fullscreen && sketchybar --trigger yabai_zoom_change

cmd + alt - b : yabai -m space --layout bsp; sketchybar --trigger yabai_layout_change
cmd + alt - x : yabai -m space --layout stack; sketchybar --trigger yabai_layout_change
cmd + alt - f : yabai -m space --layout float; sketchybar --trigger yabai_layout_change

# move windows to space
ctrl - 1 : sketchybar --set /space\../ background.drawing=off --set space.1 background.drawing=on; yabai -m space --focus 1
ctrl - 2 : sketchybar --set /space\../ background.drawing=off --set space.2 background.drawing=on; yabai -m space --focus 2
ctrl - 3 : sketchybar --set /space\../ background.drawing=off --set space.3 background.drawing=on; yabai -m space --focus 3
ctrl - 4 : sketchybar --set /space\../ background.drawing=off --set space.4 background.drawing=on; yabai -m space --focus 4
ctrl - 5 : sketchybar --set /space\../ background.drawing=off --set space.5 background.drawing=on; yabai -m space --focus 5
ctrl - 6 : sketchybar --set /space\../ background.drawing=off --set space.6 background.drawing=on; yabai -m space --focus 6
ctrl - 7 : sketchybar --set /space\../ background.drawing=off --set space.7 background.drawing=on; yabai -m space --focus 7
ctrl - 8 : sketchybar --set /space\../ background.drawing=off --set space.8 background.drawing=on; yabai -m space --focus 8
ctrl - 9 : sketchybar --set /space\../ background.drawing=off --set space.9 background.drawing=on; yabai -m space --focus 9
ctrl - 0 : sketchybar --set /space\../ background.drawing=off --set space.10 background.drawing=on; yabai -m space --focus 10

# move windows to space
ctrl + shift - 1 : sketchybar --set /space\../ background.drawing=off --set space.1 background.drawing=on; yabai -m window --space 1; yabai -m space --focus 1
ctrl + shift - 2 : sketchybar --set /space\../ background.drawing=off --set space.2 background.drawing=on; yabai -m window --space 2; yabai -m space --focus 2
ctrl + shift - 3 : sketchybar --set /space\../ background.drawing=off --set space.3 background.drawing=on; yabai -m window --space 3; yabai -m space --focus 3
